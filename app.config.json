{
  "environmentUrl": "https://guu84124.apps.dynatrace.com",
  "app": {
    "name": "Telemetry Ingest Insight",
    "version": "0.0.17",
    "id": "my.metric.ingest.insights",
    "description": "Analyze telemetry ingest volume, costs, and forecast trends.",
    "scopes": [
      { "name": "storage:metrics:read", "comment": "fetch metric.series and timeseries" },
      { "name": "storage:entities:read", "comment": "entity name lookups" },
      { "name": "storage:buckets:read", "comment": "named buckets" },
      { "name": "storage:system:read", "comment": "dt.system.events for query exec stats" }
    ]
  }
}
